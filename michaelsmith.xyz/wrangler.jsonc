{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "michaelsmith-xyz",
  "main": "src/main.tsx",
  "compatibility_date": "2026-05-08",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true,
    },
  },
  "assets": {
    "directory": "./static",
    "binding": "ASSETS",
    "run_worker_first": true,
  },
  "workers_dev": false,
  "routes": [
    {
      "pattern": "dev.michaelsmith.xyz",
      "custom_domain": true,
    },
  ],
  "env": {
    "prod": {
      "routes": [
        {
          "pattern": "michaelsmith.xyz",
          "custom_domain": true,
        },
        {
          "pattern": "www.michaelsmith.xyz",
          "custom_domain": true,
        },
      ],
    },
  },
}
