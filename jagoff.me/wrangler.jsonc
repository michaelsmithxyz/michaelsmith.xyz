{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "jagoff-me",
  "main": "src/main.ts",
  "compatibility_date": "2026-05-08",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true,
    },
  },
  "routes": [
    {
      "pattern": "dev.jagoff.me",
      "custom_domain": true,
    },
  ],
  "env": {
    "prod": {
      "routes": [
        {
          "pattern": "jagoff.me",
          "custom_domain": true,
        },
        {
          "pattern": "www.jagoff.me",
          "custom_domain": true,
        },
      ],
    },
  },
}
